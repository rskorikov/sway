include /etc/sway/config.d/*
gaps inner 10
title_align center
default_border pixel 5


# Window rules
assign [app_id="Throne"] 10
for_window [app_id="Throne"] floating enable
for_window [title="Картинка в картинке"] floating enable
for_window [app_id="org.gnome.SimpleScan"] floating enable

